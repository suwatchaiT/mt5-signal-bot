# Telegram Bot
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# MetaTrader 5 (leave blank to use the currently logged-in MT5 account)
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=

# Symbols to watch (comma-separated)
SYMBOLS=EURUSD,GBPUSD,XAUUSD

# Timeframe: M1 M5 M15 M30 H1 H4 D1
TIMEFRAME=H1

# Indicator settings
MA_FAST=9
MA_SLOW=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# How often to check for signals (seconds)
POLL_INTERVAL=60
