# Telegram Bot
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Symbols to watch (comma-separated)
# Supported: EURUSD GBPUSD USDJPY AUDUSD USDCAD USDCHF NZDUSD XAUUSD XAGUSD BTCUSD ETHUSD
SYMBOLS=EURUSD,GBPUSD,XAUUSD,BTCUSD

# Timeframe: M5 M15 M30 H1 H4 D1
TIMEFRAME=H1

# Indicator settings
MA_FAST=9
MA_SLOW=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ATR-based SL/TP suggestion
ATR_PERIOD=14
ATR_SL_MULT=1.5
ATR_TP_MULT=3.0

# Minimum confluence stars (1-3) required to alert: 1=all, 2=moderate+, 3=strong only
MIN_STARS=1

# How often to check for signals (seconds)
POLL_INTERVAL=60
